<distributed-cache name="{CACHE_NAME}">
  <encoding>
    <key media-type="application/x-protostream"/>
    <value media-type="application/x-protostream"/>
  </encoding>
  <indexing storage="local-heap">
    <indexed-entities>
      <indexed-entity>{ENTITY_NAME}</indexed-entity>
    </indexed-entities>
  </indexing>
</distributed-cache>
